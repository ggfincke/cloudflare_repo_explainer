{
  "name": "@repo-explainer/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "wrangler deploy --dry-run",
    "dev": "wrangler dev --remote",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "migrate:local": "wrangler d1 migrations apply repo-explainer-db --local",
    "migrate:remote": "wrangler d1 migrations apply repo-explainer-db --remote",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@repo-explainer/shared": "workspace:*",
    "fflate": "^0.8.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.75.0"
  }
}
