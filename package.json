{
  "name": "cloudflare-repo-explainer",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "dev:api": "pnpm --filter @repo-explainer/api dev",
    "dev:web": "pnpm --filter @repo-explainer/web dev",
    "cf-typegen": "pnpm --filter @repo-explainer/api cf-typegen"
  }
}
